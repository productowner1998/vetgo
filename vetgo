    <script>
        // ======= AUTH / LOGIN =======
        function switchAuth(stepId) {
            const views = ['auth-login', 'auth-role-select', 'auth-register-client-1', 'auth-register-client-2', 'auth-register-vet-1', 'auth-register-vet-2'];
            views.forEach(v => document.getElementById(v).classList.add('hidden'));
            document.getElementById(stepId).classList.remove('hidden');
        }

        // Nueva función dedicada para ir directamente al formulario de Vet
        function startVetRegistration() {
            document.getElementById('app-wrapper').classList.replace('block', 'hidden');
            document.getElementById('auth-wrapper').classList.replace('hidden', 'block');
            switchAuth('auth-register-vet-1');
        }

        function doLogin(modeOverride = null) {
            document.getElementById('auth-wrapper').classList.replace('block', 'hidden');
            document.getElementById('app-wrapper').classList.replace('hidden', 'block');
            
            isAppInVetMode = modeOverride === 'vet';
            updateAppModeUI();
        }

        function doLogout() {
            document.getElementById('app-wrapper').classList.replace('block', 'hidden');
            document.getElementById('auth-wrapper').classList.replace('hidden', 'block');
            switchAuth('auth-login');
        }

        // ======= MODO SWITCHER (CLIENTE <-> VET) =======
        let isAppInVetMode = false;
        function toggleAppMode() {
            isAppInVetMode = !isAppInVetMode;
            updateAppModeUI();
        }

        function updateAppModeUI() {
            const btnText = document.getElementById('mode-toggle-text');
            const clientItems = document.querySelectorAll('.client-menu-item');
            const vetItems = document.querySelectorAll('.vet-menu-item');

            if (isAppInVetMode) {
                btnText.innerText = "Cambiar a Dueño";
                clientItems.forEach(el => el.classList.add('hidden'));
                vetItems.forEach(el => el.classList.remove('hidden'));
                switchView('vet-dashboard-view');
            } else {
                btnText.innerText = "Cambiar a Especialista";
                clientItems.forEach(el => el.classList.remove('hidden'));
                vetItems.forEach(el => el.classList.add('hidden'));
                switchView('dashboard-view');
            }
        }

        // ======= SIDEBAR AND VIEW NAV =======
        function toggleSidebar() {
            const sb = document.getElementById('sidebar');
            const mc = document.getElementById('main-content');
            sb.classList.toggle('sidebar-expanded');
            sb.classList.toggle('sidebar-collapsed');
            mc.classList.toggle('main-expanded');
            mc.classList.toggle('main-collapsed');
        }
        function switchView(viewId) {
            document.querySelectorAll('.view-section').forEach(el => el.classList.add('hidden'));
            document.getElementById(viewId).classList.remove('hidden');
        }

        // ======= REQUEST MODAL AND PAYMENTS =======
        function openRequestModal() { 
            document.getElementById('request-step-1').classList.remove('hidden');
            document.getElementById('request-step-2').classList.add('hidden');
            document.getElementById('request-modal').classList.remove('hidden'); 
        }
        function closeRequestModal() { document.getElementById('request-modal').classList.add('hidden'); }

        let currentPaymentMethod = 'card';
        function selectPayment(method) {
            currentPaymentMethod = method;
            const card = document.getElementById('pay-card');
            const cash = document.getElementById('pay-cash');
            if(method === 'card') {
                card.className = "cursor-pointer flex-1 border-2 border-[#1E3A8A] bg-[#1E3A8A]/5 rounded-[24px] p-6 flex items-center gap-4 transition-all";
                card.querySelector('.w-12').className = "w-12 h-12 rounded-full bg-white flex items-center justify-center text-[#1E3A8A] shadow-sm";
                document.getElementById('check-card').classList.remove('hidden');
                cash.className = "cursor-pointer flex-1 border-2 border-gray-100 bg-white rounded-[24px] p-6 flex items-center gap-4 hover:border-gray-200 transition-all";
                cash.querySelector('.w-12').className = "w-12 h-12 rounded-full bg-gray-50 flex items-center justify-center text-[#888888] shadow-sm";
                document.getElementById('check-cash').classList.add('hidden');
            } else {
                cash.className = "cursor-pointer flex-1 border-2 border-[#1E3A8A] bg-[#1E3A8A]/5 rounded-[24px] p-6 flex items-center gap-4 transition-all";
                cash.querySelector('.w-12').className = "w-12 h-12 rounded-full bg-white flex items-center justify-center text-[#1E3A8A] shadow-sm";
                document.getElementById('check-cash').classList.remove('hidden');
                card.className = "cursor-pointer flex-1 border-2 border-gray-100 bg-white rounded-[24px] p-6 flex items-center gap-4 hover:border-gray-200 transition-all";
                card.querySelector('.w-12').className = "w-12 h-12 rounded-full bg-gray-50 flex items-center justify-center text-[#888888] shadow-sm";
                document.getElementById('check-card').classList.add('hidden');
            }
        }

        // ======= LOADERS =======
        function findVetsFlow() {
            document.getElementById('request-modal').classList.add('hidden');
            const loaderModal = document.getElementById('loader-modal');
            document.getElementById('loader-title').innerText = "Buscando profesionales...";
            document.getElementById('loader-progress-bar').style.width = "40%";
            loaderModal.classList.remove('hidden');

            setTimeout(() => {
                loaderModal.classList.add('hidden');
                document.getElementById('request-step-1').classList.add('hidden');
                document.getElementById('request-step-2').classList.remove('hidden');
                document.getElementById('request-modal').classList.remove('hidden');
            }, 1500);
        }

        function startBookingFlow() {
            closeRequestModal();
            const loaderModal = document.getElementById('loader-modal');
            document.getElementById('loader-title').innerText = currentPaymentMethod === 'card' ? "Procesando pago..." : "Registrando solicitud...";
            document.getElementById('loader-progress-bar').style.width = "20%";
            document.getElementById('loader-progress-bar').className = "h-full bg-[#F39C12] rounded-full transition-all duration-500";
            document.getElementById('loader-spinner').classList.remove('hidden');
            document.getElementById('loader-success').classList.add('hidden');
            loaderModal.classList.remove('hidden');

            setTimeout(() => {
                document.getElementById('loader-title').innerText = "¡Confirmado!";
                document.getElementById('loader-progress-bar').style.width = "100%";
                document.getElementById('loader-progress-bar').className = "h-full bg-[#2ECC71] rounded-full transition-all duration-500";
                document.getElementById('loader-spinner').classList.add('hidden');
                document.getElementById('loader-success').classList.remove('hidden');
            }, 2000);

            setTimeout(() => {
                loaderModal.classList.add('hidden');
                const trackingPill = document.getElementById('tracking-pills');
                trackingPill.classList.remove('hidden');
                setTimeout(() => trackingPill.classList.remove('translate-y-20'), 50);
            }, 3500);
        }
